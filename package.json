{
  "name": "astro-build-timestamp",
  "version": "1.0.0",
  "description": "Writes a static build timestamp file for Astro sites at build time",
  "homepage": "https://velohost.co.uk/plugins/astro-build-timestamp/",
  "repository": {
    "type": "git",
    "url": "https://github.com/velohost/astro-build-timestamp.git"
  },
  "bugs": {
    "url": "https://github.com/velohost/astro-build-timestamp/issues"
  },
  "license": "MIT",
  "type": "module",
  "keywords": [
    "withastro",
    "astro-integration",
    "build",
    "timestamp",
    "deploy",
    "static-site"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc"
  },
  "peerDependencies": {
    "astro": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^5.0.0"
  },
  "astro": {
    "integration": {
      "name": "astro-build-timestamp",
      "description": "Writes a static build timestamp file for Astro sites at build time",
      "entrypoint": "dist/index.js",
      "config": {
        "inject": true,
        "schema": {
          "filename": {
            "type": "string",
            "default": "build-timestamp.txt",
            "description": "Output filename for the build timestamp"
          },
          "format": {
            "type": "string",
            "enum": ["iso", "unix"],
            "default": "iso",
            "description": "Timestamp format"
          }
        }
      }
    }
  }
}